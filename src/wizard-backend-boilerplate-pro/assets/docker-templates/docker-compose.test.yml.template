# docker-compose.test.yml — {{APP_NAME}}
# Isolated test environment — disposable DB, exits after suite completes.
# Usage: docker compose -f docker-compose.test.yml up --build --abort-on-container-exit

services:
  api-test:
    build:
      context: .
      dockerfile: Dockerfile.Test
    environment:
      NODE_ENV: test
      DATABASE_URL: postgres://${DB_USER}:${DB_PASSWORD}@db-test:5432/{{APP_NAME}}_test
    depends_on:
      db-test:
        condition: service_healthy
    networks:
      - test-network

  db-test:
    image: postgres:16-alpine
    environment:
      POSTGRES_DB: {{APP_NAME}}_test
      POSTGRES_USER: ${DB_USER}
      POSTGRES_PASSWORD: ${DB_PASSWORD}
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DB_USER}"]
      interval: 5s
      timeout: 3s
      retries: 10
    networks:
      - test-network

networks:
  test-network:
    driver: bridge
