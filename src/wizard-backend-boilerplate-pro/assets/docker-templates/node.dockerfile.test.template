# syntax=docker/dockerfile:1
# Test Node.js — {{APP_NAME}}
# Full deps (including devDependencies) + test runner.
# Usage: docker compose -f docker-compose.test.yml up --build --abort-on-container-exit

FROM node:22-alpine
WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

ENV NODE_ENV=test

CMD ["npm", "test"]
