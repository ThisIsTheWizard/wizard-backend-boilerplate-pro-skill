# docker-compose.dev.yml — {{APP_NAME}}
# Hot-reload dev environment with bind-mounted source.
# Usage: docker compose -f docker-compose.dev.yml up --build
#
# Set DB_USER and DB_PASSWORD in your .env file before running.

services:
  api:
    build:
      context: .
      dockerfile: Dockerfile.Dev
    ports:
      - "3000:3000"
    volumes:
      - .:/app
      - /app/node_modules
    env_file:
      - .env
    environment:
      NODE_ENV: development
    depends_on:
      db:
        condition: service_healthy
    networks:
      - app-network

  # ── PostgreSQL ───────────────────────────────────────────────────────────────
  db:
    image: postgres:16-alpine
    environment:
      POSTGRES_DB: {{APP_NAME}}_dev
      POSTGRES_USER: ${DB_USER}
      POSTGRES_PASSWORD: ${DB_PASSWORD}
    ports:
      - "5432:5432"
    volumes:
      - postgres_dev_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DB_USER}"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - app-network

  # ── MySQL (uncomment if DB = mysql) ──────────────────────────────────────────
  # db:
  #   image: mysql:8.0
  #   environment:
  #     MYSQL_DATABASE: {{APP_NAME}}_dev
  #     MYSQL_USER: ${DB_USER}
  #     MYSQL_PASSWORD: ${DB_PASSWORD}
  #     MYSQL_ROOT_PASSWORD: ${DB_ROOT_PASSWORD}
  #   ports:
  #     - "3306:3306"
  #   healthcheck:
  #     test: ["CMD", "mysqladmin", "ping", "-h", "localhost"]
  #     interval: 10s
  #     timeout: 5s
  #     retries: 5

  # ── MongoDB (uncomment if DB = mongodb) ──────────────────────────────────────
  # db:
  #   image: mongo:7.0
  #   environment:
  #     MONGO_INITDB_DATABASE: {{APP_NAME}}_dev
  #   ports:
  #     - "27017:27017"

  redis:
    image: redis:7-alpine
    ports:
      - "6379:6379"
    networks:
      - app-network

volumes:
  postgres_dev_data:

networks:
  app-network:
    driver: bridge
