# syntax=docker/dockerfile:1
# Dev Node.js — {{APP_NAME}}
# Bind-mounts host source for hot reload via nodemon.
# Usage: docker compose -f docker-compose.dev.yml up --build

FROM node:22-alpine
WORKDIR /app

COPY package*.json ./
RUN npm install

# Source is bind-mounted at runtime — no COPY . . needed
EXPOSE 3000

CMD ["npm", "run", "dev"]
